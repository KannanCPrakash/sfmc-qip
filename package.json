{
  "name": "sfmc-qip",
  "displayName": "sfmc-qip",
  "description": "Interactive DE graphs for SFMC",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.106.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sfmc-qip.showGraph",
        "title": "QIP: Show DE Graph"
      },
      {
        "command": "sfmc-qip.configure",
        "title": "QIP: Configure SFMC Connection"
      }
    ],
    "configuration": {
      "title": "SFMC QIP",
      "properties": {
        "sfmcQip.subdomain": {
          "type": "string",
          "default": "",
          "description": "SFMC tenant subdomain (e.g. mc563885gzs27c5t9-63k636ttgm). Found in your installed package's Auth Base URI."
        },
        "sfmcQip.clientId": {
          "type": "string",
          "default": "",
          "description": "SFMC installed package Client ID."
        },
        "sfmcQip.accountId": {
          "type": "string",
          "default": "",
          "description": "SFMC MID (Account ID). Required when connecting to a child business unit."
        }
      }
    },
    "menus": {
      "explorer/context": [
        {
          "command": "sfmc-qip.showGraph",
          "group": "z_commands",
          "when": "resourceExtname =~ /\\.(sql|json|txt)$/i || resourceFilename =~ /_DE_|Query/i",
          "title": "QIP: Show DE ↔ Query Graph"
        }
      ],
      "explorer/context/multi": [
        {
          "command": "sfmc-qip.showGraph",
          "when": "resourceExtname =~ /\\.(sql|json)$/i",
          "group": "navigation",
          "alt": "sfmc-qip.showGraph"
        }
      ]
    }
  },
  "scripts": {
    "install:all": "npm install && cd webview-ui && npm install",
    "start:webview": "cd webview-ui && npm run start",
    "build:webview": "cd webview-ui && npm run build",
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "test:unit": "mocha --require ts-node/register src/test/unit/**/*.test.ts"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.1",
    "@types/vscode": "^1.106.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.1",
    "mocha": "^10.8.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3",
    "vite": "^7.2.4"
  },
  "dependencies": {
    "glob": "^13.0.0",
    "reactflow": "^11.11.4"
  }
}
